<UserControl
    x:Class="Openza.Tasks.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Openza.Tasks.ViewModels">
    <UserControl.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="1,30,0,6" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{ThemeResource OpenzaAppCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            MaxWidth="1064"
            Margin="36,24,36,0"
            AutomationProperties.HeadingLevel="Level1"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Settings" />

        <ScrollViewer
            x:Name="SettingsContentScrollViewer"
            Grid.Row="1"
            Padding="36,0,36,0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="1064"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource SettingsCardSpacing}">
                <StackPanel.ChildrenTransitions>
                    <RepositionThemeTransition />
                </StackPanel.ChildrenTransitions>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Appearance" />
                <StackPanel x:Name="AppearancePanel" Spacing="{StaticResource SettingsCardSpacing}">
                    <toolkit:SettingsCard Header="Theme" Description="Choose how Openza Tasks follows Windows.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE771;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="ThemeCombo"
                            MinWidth="180"
                            SelectionChanged="OnThemeChanged">
                            <ComboBoxItem Content="System" Tag="System" IsSelected="True" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>
                    </toolkit:SettingsCard>
                </StackPanel>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Integrations" />
                <StackPanel x:Name="IntegrationsPanel" Spacing="{StaticResource SettingsCardSpacing}">
                    <toolkit:SettingsCard Header="How integrations work" Description="Connected apps bring tasks into Openza. Your Openza planning stays in Openza.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE946;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <StackPanel Spacing="4">
                            <TextBlock
                                Text="Imported tasks wait in Inbox review before they become Openza tasks."
                                Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Text="When supported, completing a task in Openza can complete it in the connected app too."
                                Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard Header="Automatic sync" Description="Refresh connected apps while Openza Tasks is running.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE895;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <ToggleSwitch
                            x:Name="AutoSyncSwitch"
                            OnContent="On"
                            OffContent="Off"
                            AutomationProperties.Name="Automatic sync"
                            Toggled="OnAutoSyncToggled" />
                    </toolkit:SettingsCard>

                    <toolkit:SettingsExpander Header="Todoist" Description="Import tasks, projects, labels, dates, and priorities from Todoist.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE73E;" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <Border
                            MinWidth="112"
                            Padding="12,5"
                            CornerRadius="14"
                            Background="{ThemeResource OpenzaChipBackgroundBrush}">
                            <TextBlock
                                x:Name="TodoistStatusText"
                                Text="Not connected"
                                Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                TextAlignment="Center" />
                        </Border>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard Header="API token" Description="Saved securely in Windows.">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <PasswordBox
                                        x:Name="TodoistTokenBox"
                                        MinWidth="260"
                                        PlaceholderText="Paste Todoist token"
                                        AutomationProperties.Name="Todoist API token" />
                                    <Button
                                        x:Name="TodoistConnectButton"
                                        Grid.Column="1"
                                        Content="Connect"
                                        Style="{StaticResource OpenzaAccentButtonStyle}"
                                        Click="OnConnectTodoistClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard Header="Connection" Description="Openza keeps Todoist task details linked for sync.">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock
                                        x:Name="TodoistSummaryText"
                                        Text="Paste a Todoist API token to connect your account."
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        x:Name="TodoistDisconnectButton"
                                        Grid.Column="1"
                                        Content="Disconnect"
                                        Click="OnDisconnectTodoistClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                Header="Rules"
                                Description="Send new Todoist tasks to a Space by label."
                                ContentAlignment="Left">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Text="Todoist labels stay hidden from your normal task labels."
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="TodoistRulesEmptyText"
                                        Grid.Row="1"
                                        Text="No rules yet."
                                        Style="{StaticResource OpenzaCaptionTextBlockStyle}" />
                                    <ListView
                                        x:Name="TodoistRulesList"
                                        Grid.Row="1"
                                        MaxHeight="260"
                                        ItemsSource="{x:Bind TodoistRules, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,0,8" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TodoistRoutingRuleViewModel">
                                                <Border
                                                    Padding="12"
                                                    CornerRadius="8"
                                                    BorderBrush="{ThemeResource OpenzaBorderBrush}"
                                                    BorderThickness="1">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{x:Bind LabelText}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                            <TextBlock
                                                                Text="{x:Bind SummaryText}"
                                                                Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                                                TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <StackPanel
                                                            Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Center">
                                                            <Button
                                                                Content="Edit"
                                                                Tag="{x:Bind Id}"
                                                                Click="OnEditTodoistRuleClicked" />
                                                            <Button
                                                                Content="Delete"
                                                                Tag="{x:Bind Id}"
                                                                Click="OnDeleteTodoistRuleClicked" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <Button
                                        Grid.Row="2"
                                        Content="Add rule"
                                        HorizontalAlignment="Left"
                                        Click="OnAddTodoistRuleClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                    <toolkit:SettingsExpander Header="Microsoft To Do" Description="Choose the Microsoft account Openza uses for Microsoft To Do.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE787;" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <Border
                            MinWidth="112"
                            Padding="12,5"
                            CornerRadius="14"
                            Background="{ThemeResource OpenzaChipBackgroundBrush}">
                            <TextBlock
                                x:Name="MicrosoftStatusText"
                                Text="Not connected"
                                Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                TextAlignment="Center" />
                        </Border>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard Header="Connection" Description="Openza keeps Microsoft To Do task details linked for sync.">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock
                                        x:Name="MicrosoftSummaryText"
                                        Text="Choose a Microsoft account for Microsoft To Do."
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        x:Name="MicrosoftConnectButton"
                                        Grid.Column="1"
                                        Content="Connect"
                                        Style="{StaticResource OpenzaAccentButtonStyle}"
                                        Click="OnConnectMicrosoftClicked" />
                                    <Button
                                        x:Name="MicrosoftDisconnectButton"
                                        Grid.Column="2"
                                        Content="Disconnect"
                                        Click="OnDisconnectMicrosoftClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>

                    <toolkit:SettingsExpander Header="GitHub" Description="Create GitHub issues from Openza tasks.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE943;" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <Border
                            MinWidth="112"
                            Padding="12,5"
                            CornerRadius="14"
                            Background="{ThemeResource OpenzaChipBackgroundBrush}">
                            <TextBlock
                                x:Name="GitHubStatusText"
                                Text="Not connected"
                                Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                TextAlignment="Center" />
                        </Border>
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard Header="GitHub account" Description="Sign in to create issues in repositories you can access.">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock
                                        Text="Recommended. Opens GitHub in your browser and stores the approved token securely in Windows."
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        x:Name="GitHubSignInButton"
                                        Grid.Column="1"
                                        Content="Sign in with GitHub"
                                        Style="{StaticResource OpenzaAccentButtonStyle}"
                                        Click="OnSignInGitHubClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard Header="Token fallback" Description="Use only when browser sign-in is unavailable.">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <PasswordBox
                                        x:Name="GitHubTokenBox"
                                        MinWidth="260"
                                        PlaceholderText="Paste GitHub token"
                                        AutomationProperties.Name="GitHub token" />
                                    <Button
                                        x:Name="GitHubConnectButton"
                                        Grid.Column="1"
                                        Content="Use token"
                                        Click="OnConnectGitHubClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard Header="Status" Description="Openza can publish tasks as GitHub issues. It does not sync issue status in V1.">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock
                                        x:Name="GitHubSummaryText"
                                        Text="Connect GitHub to create issues from tasks."
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        x:Name="GitHubDisconnectButton"
                                        Grid.Column="1"
                                        Content="Disconnect"
                                        Click="OnDisconnectGitHubClicked" />
                                </Grid>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>
                </StackPanel>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Spaces" />
                <StackPanel x:Name="SpacesPanel" Spacing="{StaticResource SettingsCardSpacing}">
                    <InfoBar
                        x:Name="SpacesInfo"
                        IsOpen="False"
                        IsClosable="True"
                        Severity="Informational" />

                    <toolkit:SettingsCard Header="Add space" Description="Create another place to keep tasks and projects separate.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE710;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox
                                x:Name="NewSpaceNameBox"
                                MinWidth="220"
                                PlaceholderText="Space name"
                                AutomationProperties.Name="New space name" />
                            <Button
                                Grid.Column="1"
                                Content="Add"
                                Style="{StaticResource OpenzaAccentButtonStyle}"
                                Click="OnAddSpaceClicked" />
                        </Grid>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsExpander Header="Manage spaces" Description="Rename or archive spaces. Archiving hides a space but keeps its tasks.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8B7;" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <TextBlock
                            x:Name="SpacesCountText"
                            Text="0 spaces"
                            Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard ContentAlignment="Left">
                                <ListView
                                    x:Name="SpacesList"
                                    MaxHeight="420"
                                    ItemsSource="{x:Bind Spaces, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,8" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SpaceSettingsItemViewModel">
                                            <Border
                                                Padding="12"
                                                CornerRadius="8"
                                                BorderBrush="{ThemeResource OpenzaBorderBrush}"
                                                BorderThickness="1">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Spacing="6">
                                                        <TextBox
                                                            Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            AutomationProperties.Name="Space name" />
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock
                                                                Text="{x:Bind DetailText, Mode=OneWay}"
                                                                Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                                            <Border
                                                                Padding="7,1"
                                                                CornerRadius="8"
                                                                Background="{ThemeResource OpenzaChipBackgroundBrush}"
                                                                Visibility="{x:Bind CurrentVisibility, Mode=OneWay}">
                                                                <TextBlock
                                                                    Text="Current"
                                                                    Style="{StaticResource OpenzaCaptionTextBlockStyle}" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                        <Button
                                                            Content="Rename"
                                                            Tag="{x:Bind Id, Mode=OneWay}"
                                                            Click="OnRenameSpaceClicked" />
                                                        <Button
                                                            Content="Archive"
                                                            Tag="{x:Bind Id, Mode=OneWay}"
                                                            IsEnabled="{x:Bind CanArchive, Mode=OneWay}"
                                                            Click="OnArchiveSpaceClicked" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>
                </StackPanel>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Backups" />
                <StackPanel x:Name="BackupsPanel" Spacing="{StaticResource SettingsCardSpacing}">
                    <toolkit:SettingsCard
                        x:Name="OneDriveBackupCard"
                        Header="OneDrive backup"
                        Description="Recommended backup that can help if this PC is lost or you reinstall the app."
                        ContentAlignment="Left">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE753;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border
                                    MinWidth="112"
                                    Padding="12,5"
                                    CornerRadius="14"
                                    Background="{ThemeResource OpenzaChipBackgroundBrush}">
                                    <TextBlock
                                        x:Name="OneDriveBackupStatusText"
                                        Text="Off"
                                        Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                        TextAlignment="Center" />
                                </Border>
                                <TextBlock
                                    x:Name="OneDriveBackupAccountText"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                    Text="No account selected."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                x:Name="OneDriveBackupSummaryText"
                                Grid.Row="1"
                                Text="OneDrive backup is off."
                                Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                x:Name="OneDriveBackupDetailText"
                                Grid.Row="2"
                                Text="Stored in your OneDrive. You can add a passphrase in Advanced."
                                Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Name="OneDrivePrimaryButton"
                                    Content="Turn on"
                                    Click="OnOneDriveBackupPrimaryClicked" />
                                <Button
                                    x:Name="OneDriveRestoreButton"
                                    Content="Restore"
                                    Click="OnShowOneDriveRestoreDialogClicked" />
                            </StackPanel>
                        </Grid>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsCard Header="Backup file" Description="Save a backup file yourself, or restore from one.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8E5;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Export backup file" Click="OnExportBackupFileClicked" />
                            <Button Content="Restore from file" Click="OnRestoreBackupClicked" />
                        </StackPanel>
                    </toolkit:SettingsCard>

                    <toolkit:SettingsExpander Header="Advanced" Description="Restore points, OneDrive account, and passphrase settings.">
                        <toolkit:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE713;" />
                        </toolkit:SettingsExpander.HeaderIcon>
                        <TextBlock Text="Optional" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                        <toolkit:SettingsExpander.Items>
                            <toolkit:SettingsCard Header="Restore points" Description="Local snapshots for undoing recent changes on this PC. Use backup files or OneDrive for long-term backup." ContentAlignment="Left">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            x:Name="LatestRestorePointText"
                                            Text="No restore points yet."
                                            Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            x:Name="RestorePointCountText"
                                            Text="0 restore points"
                                            Style="{StaticResource OpenzaCaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <TextBlock
                                            Text="Create restore points automatically"
                                            Style="{StaticResource OpenzaMetadataTextBlockStyle}"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Center" />
                                        <ToggleSwitch
                                            x:Name="AutoBackupSwitch"
                                            Grid.Column="1"
                                            AutomationProperties.Name="Automatic restore point"
                                            Toggled="OnAutoBackupToggled" />
                                    </Grid>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                        <Button Content="Create restore point" Click="OnCreateBackupClicked" />
                                        <Button Content="Manage" Click="OnManageRestorePointsClicked" />
                                    </StackPanel>
                                </Grid>
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                x:Name="AdvancedOneDriveBackupCard"
                                Header="OneDrive backup"
                                Description="Keep a backup in OneDrive. Recommended because Openza stores your tasks on this PC.">
                                <ToggleSwitch
                                    x:Name="OneDriveBackupSwitch"
                                    OnContent="On"
                                    OffContent="Off"
                                    AutomationProperties.Name="OneDrive cloud backup"
                                    Toggled="OnOneDriveBackupToggled" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                x:Name="AdvancedOneDriveEncryptionCard"
                                Header="Passphrase encryption"
                                Description="Add your own passphrase to OneDrive backup files. Restore on a new PC requires the passphrase.">
                                <ToggleSwitch
                                    x:Name="OneDriveEncryptionSwitch"
                                    OnContent="Encrypted"
                                    OffContent="OneDrive only"
                                    AutomationProperties.Name="OneDrive backup passphrase encryption"
                                    Toggled="OnOneDriveEncryptionToggled" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                x:Name="AdvancedOneDriveAccountCard"
                                Header="OneDrive account"
                                Description="Change the Microsoft account used for OneDrive backups.">
                                <Button Content="Account" Click="OnChangeOneDriveAccountClicked" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard
                                x:Name="AdvancedOneDrivePassphraseCard"
                                Header="Passphrase"
                                Description="Change the passphrase for encrypted OneDrive backups.">
                                <Button Content="Passphrase" Click="OnChangeOneDrivePassphraseClicked" />
                            </toolkit:SettingsCard>
                        </toolkit:SettingsExpander.Items>
                    </toolkit:SettingsExpander>
                </StackPanel>

                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="About" />
                <StackPanel x:Name="AboutPanel" Spacing="{StaticResource SettingsCardSpacing}" Margin="0,0,0,36">
                    <toolkit:SettingsCard Header="Openza Tasks" Description="A local-first task app under the Openza umbrella.">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE946;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Local data format: V1" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                            <TextBlock
                                Text="Maintainer and Microsoft publisher contact: deependra@solanky.dev"
                                Style="{StaticResource OpenzaCaptionTextBlockStyle}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </toolkit:SettingsCard>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
