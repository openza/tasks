<UserControl
    x:Class="Openza.Tasks.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Openza.Tasks.Controls"
    xmlns:vm="using:Openza.Tasks.ViewModels">
    <Grid
        x:Name="WorkbenchRoot"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        ColumnSpacing="0"
        SizeChanged="OnWorkbenchSizeChanged">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ProjectsColumn" Width="330" />
            <ColumnDefinition x:Name="ListColumn" Width="*" MinWidth="420" />
            <ColumnDefinition x:Name="DetailsColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <controls:ProjectsPaneControl
            x:Name="ProjectsPane"
            ProjectGroups="{x:Bind ViewModel.ProjectGroups, Mode=OneWay}"
            SearchTextChanged="OnProjectSearchTextChanged"
            ProjectSelected="OnProjectSelected"
            AddProjectClicked="OnAddProjectClicked"
            EditProjectClicked="OnEditProjectClicked"
            DeleteProjectClicked="OnDeleteProjectClicked" />

        <Grid
            x:Name="ListHost"
            Grid.Column="1"
            Padding="{StaticResource PagePadding}"
            RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                        Style="{ThemeResource TitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock
                            Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                            Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                        <HyperlinkButton
                            x:Name="ClearProjectButton"
                            Padding="0"
                            Content="All projects"
                            Visibility="Collapsed"
                            Click="OnClearProjectClicked" />
                    </StackPanel>
                </StackPanel>
                <CommandBar
                    Grid.Column="1"
                    Background="Transparent"
                    DefaultLabelPosition="Right">
                    <AppBarButton
                        x:Name="ProjectsCommand"
                        Icon="Folder"
                        Label="Projects"
                        Visibility="Collapsed"
                        Click="OnProjectsCommandClicked" />
                    <AppBarButton
                        Icon="Add"
                        Label="Add task"
                        Click="OnQuickAddClicked"
                        ToolTipService.ToolTip="Add task (Ctrl+N)" />
                    <CommandBar.SecondaryCommands>
                        <AppBarButton Icon="Import" Label="Import Markdown" Click="OnImportClicked" />
                        <AppBarButton Icon="Save" Label="Export Markdown" Click="OnExportClicked" />
                    </CommandBar.SecondaryCommands>
                </CommandBar>
            </Grid>

            <Grid
                x:Name="FilterGrid"
                Grid.Row="1"
                Margin="0,22,0,16"
                ColumnSpacing="10"
                RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="190" />
                </Grid.ColumnDefinitions>
                <AutoSuggestBox
                    x:Name="SearchBox"
                    PlaceholderText="Search tasks"
                    QueryIcon="Find"
                    TextChanged="OnSearchTextChanged" />
                <ComboBox
                    x:Name="SortCombo"
                    Grid.Column="1"
                    SelectionChanged="OnSortChanged">
                    <ComboBoxItem Content="Priority" Tag="priority" IsSelected="True" />
                    <ComboBoxItem Content="Due date" Tag="due" />
                    <ComboBoxItem Content="Newest" Tag="created" />
                    <ComboBoxItem Content="Title" Tag="title" />
                </ComboBox>
                <ComboBox
                    x:Name="PriorityCombo"
                    Grid.Column="2"
                    SelectionChanged="OnPriorityChanged">
                    <ComboBoxItem Content="All priorities" Tag="" IsSelected="True" />
                    <ComboBoxItem Content="Urgent" Tag="1" />
                    <ComboBoxItem Content="High" Tag="2" />
                    <ComboBoxItem Content="Normal" Tag="3" />
                    <ComboBoxItem Content="Low" Tag="4" />
                </ComboBox>
                <ComboBox
                    x:Name="LabelCombo"
                    Grid.Column="3"
                    SelectionChanged="OnLabelChanged" />
            </Grid>

            <Grid Grid.Row="2">
                <ListView
                    x:Name="TaskList"
                    ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                    SelectionChanged="OnTaskSelectionChanged"
                    Visibility="{x:Bind ViewModel.ListVisibility, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskListItemViewModel">
                            <controls:TaskRowControl
                                ToggleCompleteClicked="OnToggleCompleteClicked"
                                CopyTaskIdClicked="OnCopyTaskIdClicked"
                                DeleteTaskClicked="OnDeleteTaskClicked" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <controls:EmptyStateControl
                    x:Name="EmptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ActionClicked="OnEmptyStateActionClicked"
                    Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}" />
            </Grid>
        </Grid>

        <Border
            x:Name="DetailsHost"
            Grid.Column="2"
            Visibility="Collapsed"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1,0,0,0">
            <controls:TaskDetailsPaneControl
                x:Name="TaskDetailsPanel"
                SaveTaskClicked="OnSaveTaskClicked"
                ToggleCompleteClicked="OnDetailsToggleCompleteClicked"
                DeleteTaskClicked="OnDetailsDeleteTaskClicked"
                CancelEditClicked="OnDetailsCancelEditClicked" />
        </Border>
    </Grid>
</UserControl>
