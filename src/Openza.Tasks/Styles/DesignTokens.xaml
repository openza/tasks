<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="PanePadding">22,22</Thickness>
    <Thickness x:Key="PagePadding">28,28</Thickness>
    <CornerRadius x:Key="OpenzaPaneCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="OpenzaRowCornerRadius">8</CornerRadius>

    <SolidColorBrush x:Key="OpenzaAccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="OpenzaQuietBorderBrush" Color="#1F000000" />
    <SolidColorBrush x:Key="OpenzaQuietSurfaceBrush" Color="#08000000" />
    <SolidColorBrush x:Key="OpenzaQuietHoverBrush" Color="#0F000000" />
    <SolidColorBrush x:Key="OpenzaDangerBrush" Color="#B42318" />

    <Style x:Key="OpenzaSectionHeaderTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="Margin" Value="0,20,0,6" />
    </Style>

    <Style x:Key="OpenzaFormSectionHeaderTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style x:Key="OpenzaMetadataTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="OpenzaCaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="OpenzaIconButtonStyle" TargetType="AppBarButton">
        <Setter Property="IsCompact" Value="True" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style x:Key="OpenzaIconOnlyButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

</ResourceDictionary>
