<UserControl
    x:Class="Openza.Tasks.Controls.TaskRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Openza.Tasks.ViewModels">
    <Border
        x:Name="RowSurface"
        Margin="0"
        Padding="10,9"
        CornerRadius="4"
        BorderBrush="{ThemeResource OpenzaSeparatorBrush}"
        BorderThickness="0,0,0,1"
        Background="{ThemeResource OpenzaRowBackgroundBrush}"
        Tapped="OnRowTapped"
        PointerEntered="OnPointerEntered"
        PointerExited="OnPointerExited">
        <Grid
            MinHeight="{Binding RowMinHeight}"
            ColumnDefinitions="36,*,Auto"
            ColumnSpacing="12">
            <CheckBox
                x:Name="CompleteCheckBox"
                Width="{Binding CheckboxSize}"
                Height="{Binding CheckboxSize}"
                Padding="0"
                VerticalAlignment="Top"
                IsChecked="{Binding IsCompleted, Mode=OneWay}"
                Tag="{Binding Id}"
                Click="OnToggleCompleteClicked"
                AutomationProperties.Name="{Binding CompletionAutomationName}" />

            <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock
                    Text="{Binding Title}"
                    FontSize="14"
                    FontWeight="{Binding TitleWeight}"
                    Opacity="{Binding TitleOpacity}"
                    MaxLines="3"
                    IsTextSelectionEnabled="True"
                    TextWrapping="WrapWholeWords"
                    TextTrimming="CharacterEllipsis" />
                <Grid>
                    <ItemsControl
                        ItemsSource="{Binding MetadataItems}"
                        Opacity="{Binding MetadataOpacity}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskMetadataPartViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock
                                        Text="&#x2022;"
                                        Visibility="{Binding SeparatorVisibility}"
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock
                                        Text="{Binding Text}"
                                        MaxLines="1"
                                        IsTextSelectionEnabled="True"
                                        TextTrimming="CharacterEllipsis"
                                        Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>

            <StackPanel
                x:Name="ActionsBar"
                Grid.Column="2"
                Width="260"
                Orientation="Horizontal"
                Spacing="4"
                Opacity="0"
                Visibility="{Binding QuickActionsVisibility}"
                GotFocus="OnActionsGotFocus"
                LostFocus="OnActionsLostFocus"
                VerticalAlignment="Center">
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    ToolTipService.ToolTip="Change date"
                    AutomationProperties.Name="Change task date">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="300" Spacing="8">
                                <CalendarView SelectionMode="Single" SelectedDatesChanged="OnRowDateSelected" />
                                <Button Content="Clear date" HorizontalAlignment="Stretch" Click="OnClearDateClicked" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <FontIcon Glyph="&#xE787;" FontSize="14" />
                </Button>
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    Click="OnChangeProjectClicked"
                    ToolTipService.ToolTip="Change project"
                    AutomationProperties.Name="Change task project">
                    <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                </Button>
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    Click="OnChangeLabelsClicked"
                    ToolTipService.ToolTip="Change labels"
                    AutomationProperties.Name="Change task labels">
                    <FontIcon Glyph="&#xE8EC;" FontSize="14" />
                </Button>
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    ToolTipService.ToolTip="Change status"
                    AutomationProperties.Name="Change task status">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Inbox" Tag="inbox" Click="OnStatusMenuItemClicked" />
                            <MenuFlyoutItem Text="Next" Tag="next" Click="OnStatusMenuItemClicked" />
                            <MenuFlyoutItem Text="Waiting For" Tag="waiting" Click="OnStatusMenuItemClicked" />
                            <MenuFlyoutItem Text="Someday" Tag="someday" Click="OnStatusMenuItemClicked" />
                        </MenuFlyout>
                    </Button.Flyout>
                    <FontIcon Glyph="&#xE8FD;" FontSize="14" />
                </Button>
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    ToolTipService.ToolTip="Change priority"
                    AutomationProperties.Name="Change task priority">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Urgent" Tag="1" Click="OnPriorityMenuItemClicked" />
                            <MenuFlyoutItem Text="High" Tag="2" Click="OnPriorityMenuItemClicked" />
                            <MenuFlyoutItem Text="Normal" Tag="3" Click="OnPriorityMenuItemClicked" />
                            <MenuFlyoutItem Text="Low" Tag="4" Click="OnPriorityMenuItemClicked" />
                        </MenuFlyout>
                    </Button.Flyout>
                    <FontIcon Glyph="&#xE7C1;" FontSize="14" />
                </Button>
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    Click="OnMoveToSpaceClicked"
                    ToolTipService.ToolTip="Move to Space"
                    AutomationProperties.Name="Move task to another Space">
                    <FontIcon Glyph="&#xE8AB;" FontSize="14" />
                </Button>
                <Button
                    Style="{StaticResource OpenzaIconOnlyButtonStyle}"
                    Tag="{Binding Id}"
                    Click="OnDeleteButtonClicked"
                    ToolTipService.ToolTip="Delete task"
                    AutomationProperties.Name="Delete task">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
