<UserControl
    x:Class="Openza.Tasks.Controls.TaskRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Openza.Tasks.ViewModels">
    <Border
        x:Name="RowSurface"
        Margin="0"
        Padding="12,8"
        CornerRadius="0"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,0,0,1"
        Background="Transparent"
        PointerEntered="OnPointerEntered"
        PointerExited="OnPointerExited">
        <Grid
            MinHeight="50"
            ColumnDefinitions="36,*,Auto"
            ColumnSpacing="12">
            <CheckBox
                Width="24"
                Height="24"
                Padding="0"
                VerticalAlignment="Top"
                IsChecked="{Binding Task.IsCompleted, Mode=OneWay}"
                Tag="{Binding Id}"
                Click="OnToggleCompleteClicked"
                AutomationProperties.Name="{Binding CompletionAutomationName}" />

            <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock
                    Text="{Binding Title}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Text="{Binding MetadataText}"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                <TextBlock
                    Text="{Binding SecondaryText}"
                    Visibility="{Binding SecondaryTextVisibility}"
                    MaxLines="1"
                    TextTrimming="CharacterEllipsis"
                    Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
            </StackPanel>

            <CommandBar
                x:Name="ActionsBar"
                Grid.Column="2"
                DefaultLabelPosition="Collapsed"
                Background="Transparent"
                OverflowButtonVisibility="Collapsed"
                Opacity="0"
                GotFocus="OnActionsGotFocus"
                LostFocus="OnActionsLostFocus"
                VerticalAlignment="Center">
                <AppBarButton
                    Style="{StaticResource OpenzaIconButtonStyle}"
                    Icon="Copy"
                    Label="Copy task ID"
                    Tag="{Binding Id}"
                    Click="OnCopyTaskIdClicked" />
                <AppBarButton
                    Style="{StaticResource OpenzaIconButtonStyle}"
                    Icon="Delete"
                    Label="Delete task"
                    Tag="{Binding Id}"
                    Click="OnDeleteTaskClicked" />
            </CommandBar>
        </Grid>
    </Border>
</UserControl>
