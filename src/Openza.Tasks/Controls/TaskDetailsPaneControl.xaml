<UserControl
    x:Class="Openza.Tasks.Controls.TaskDetailsPaneControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowDefinitions="Auto,*,Auto" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid Padding="20,18" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <CheckBox
                    x:Name="HeaderCompleteBox"
                    Width="26"
                    Height="26"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="0"
                    Margin="0,2,0,0"
                    VerticalAlignment="Top"
                    Click="OnToggleCompleteClicked"
                    ToolTipService.ToolTip="Complete task"
                    AutomationProperties.Name="Complete task" />
                <StackPanel
                    Grid.Column="1"
                    MaxWidth="360"
                    Spacing="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    <TextBlock
                        x:Name="HeaderTitleText"
                        Text="Task details"
                        FontSize="20"
                        FontWeight="SemiBold"
                        MaxLines="3"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Left"
                        HorizontalAlignment="Left" />
                    <TextBlock
                        x:Name="SourceText"
                        TextAlignment="Left"
                        HorizontalAlignment="Left"
                        Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                </StackPanel>
            <Button
                Grid.Column="2"
                Width="36"
                Height="36"
                Padding="0"
                Click="OnCancelEditClicked"
                ToolTipService.ToolTip="Close details"
                AutomationProperties.Name="Close task details">
                <FontIcon Glyph="&#xE711;" FontSize="14" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="22,18,22,18" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14">
                <StackPanel x:Name="EditableTaskSection" Spacing="10">
                    <TextBlock Text="Task" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <TextBox
                        x:Name="TitleEditor"
                        Header="Title"
                        PlaceholderText="Task title"
                        HorizontalAlignment="Stretch"
                        TextChanged="OnEditorChanged" />
                    <TextBox
                        x:Name="DescriptionEditor"
                        Header="Description"
                        PlaceholderText=""
                        AcceptsReturn="True"
                        MinHeight="76"
                        HorizontalAlignment="Stretch"
                        TextChanged="OnEditorChanged" />
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock x:Name="OrganizeHeader" Text="Organize" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <ComboBox
                            x:Name="WorkflowEditor"
                            Header="Status"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnWorkflowSelectionChanged">
                            <ComboBoxItem Content="Inbox" Tag="inbox" IsSelected="True" />
                            <ComboBoxItem Content="Open" Tag="none" />
                            <ComboBoxItem Content="Next" Tag="next" />
                            <ComboBoxItem Content="Waiting For" Tag="waiting" />
                            <ComboBoxItem Content="Someday/Maybe" Tag="someday" />
                        </ComboBox>
                        <CalendarDatePicker
                            x:Name="DateEditor"
                            Grid.Column="1"
                            Header="Date"
                            HorizontalAlignment="Stretch"
                            DateChanged="OnTaskDateChanged" />
                        <ComboBox
                            x:Name="ProjectEditor"
                            Grid.Row="1"
                            Header="Project"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Id"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnProjectSelectionChanged" />
                        <CalendarDatePicker
                            x:Name="DeadlineDateEditor"
                            Grid.Row="1"
                            Grid.Column="1"
                            Header="Deadline"
                            HorizontalAlignment="Stretch"
                            DateChanged="OnTaskDateChanged" />
                        <ComboBox
                            x:Name="PriorityEditor"
                            Grid.Row="2"
                            Header="Priority"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnSelectionChanged">
                            <ComboBoxItem Content="Urgent" Tag="1" />
                            <ComboBoxItem Content="High" Tag="2" />
                            <ComboBoxItem Content="Normal" Tag="3" />
                            <ComboBoxItem Content="Low" Tag="4" />
                        </ComboBox>
                        <AutoSuggestBox
                            x:Name="LabelEditor"
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Header="Labels"
                            PlaceholderText="Add label"
                            QueryIcon="Add"
                            GotFocus="OnLabelEditorGotFocus"
                            TextChanged="OnLabelTextChanged"
                            QuerySubmitted="OnLabelSubmitted"
                            SuggestionChosen="OnLabelSuggestionChosen" />
                    </Grid>
                    <ScrollViewer
                        MaxHeight="36"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollMode="Disabled">
                        <ItemsControl x:Name="SelectedLabelsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Margin="0,0,6,6"
                                        Padding="10,4"
                                        Click="OnRemoveLabelClicked"
                                        Tag="{Binding Id}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" />
                                            <FontIcon Glyph="&#xE711;" FontSize="10" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <TextBox
                    x:Name="LabelsEditor"
                    Visibility="Collapsed"
                    Header="Labels"
                    HorizontalAlignment="Stretch"
                    TextChanged="OnEditorChanged" />
                <StackPanel Spacing="10">
                    <TextBlock Text="Notes" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <TextBox
                        x:Name="NotesEditor"
                        PlaceholderText=""
                        AcceptsReturn="True"
                        MinHeight="128"
                        HorizontalAlignment="Stretch"
                        TextChanged="OnEditorChanged" />
                </StackPanel>

                <StackPanel x:Name="ProviderTaskSection" Spacing="10" Visibility="Collapsed">
                    <TextBlock Text="Source task" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <Border
                        Padding="12"
                        CornerRadius="6"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Text="Title"
                                    Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                <TextBlock
                                    x:Name="ProviderTitleText"
                                    TextWrapping="Wrap"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock
                                x:Name="ProviderDescriptionText"
                                TextWrapping="Wrap"
                                MaxLines="4"
                                Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Project" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderProjectText" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Date" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderDateText" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Spacing="2">
                                    <TextBlock Text="Deadline" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderDeadlineText" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Priority" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderPriorityText" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Spacing="2">
                                    <TextBlock Text="Source" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderSourceText" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid
            Grid.Row="2"
            Padding="20,14"
            ColumnDefinitions="Auto,Auto,*,Auto,Auto"
            ColumnSpacing="8"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Button
                x:Name="SaveButton"
                Content="Save"
                Style="{StaticResource AccentButtonStyle}"
                Click="OnSaveTaskClicked" />
            <Button
                Grid.Column="1"
                Content="Cancel"
                Click="OnCancelEditClicked" />
            <Button
                x:Name="DeleteButton"
                Grid.Column="3"
                Content="Delete"
                IsEnabled="False"
                Click="OnDeleteTaskClicked" />
            <Button
                x:Name="CompleteButton"
                Grid.Column="4"
                Content="Complete"
                IsEnabled="False"
                Click="OnToggleCompleteClicked" />
        </Grid>
    </Grid>
</UserControl>
