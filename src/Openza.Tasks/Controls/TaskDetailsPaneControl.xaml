<UserControl
    x:Class="Openza.Tasks.Controls.TaskDetailsPaneControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Openza.Tasks.Core.Models"
    xmlns:vm="using:Openza.Tasks.ViewModels">
    <Grid RowDefinitions="Auto,*,Auto" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid Padding="20,18" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <CheckBox
                    x:Name="HeaderCompleteBox"
                    Width="26"
                    Height="26"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="0"
                    Margin="0,2,0,0"
                    VerticalAlignment="Top"
                    Click="OnToggleCompleteClicked"
                    ToolTipService.ToolTip="Complete task"
                    AutomationProperties.Name="Complete task" />
                <StackPanel
                    Grid.Column="1"
                    MaxWidth="360"
                    Spacing="2"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    <TextBlock
                        x:Name="HeaderTitleText"
                        Text="Task details"
                        FontSize="20"
                        FontWeight="SemiBold"
                        MaxLines="3"
                        TextWrapping="WrapWholeWords"
                        TextAlignment="Left"
                        HorizontalAlignment="Left" />
                    <TextBlock
                        x:Name="SourceText"
                        TextAlignment="Left"
                        HorizontalAlignment="Left"
                        Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                </StackPanel>
            <Button
                Grid.Column="2"
                Width="36"
                Height="36"
                Padding="0"
                Click="OnCancelEditClicked"
                ToolTipService.ToolTip="Close details"
                AutomationProperties.Name="Close task details">
                <FontIcon Glyph="&#xE711;" FontSize="14" />
            </Button>
        </Grid>

        <ScrollViewer
            x:Name="DetailsScrollViewer"
            Grid.Row="1"
            Padding="22,18,22,18"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14">
                <StackPanel x:Name="EditableTaskSection" Spacing="10">
                    <TextBlock Text="Task" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <TextBox
                        x:Name="TitleEditor"
                        Header="Title"
                        PlaceholderText="Task title"
                        HorizontalAlignment="Stretch"
                        TextChanged="OnEditorChanged" />
                </StackPanel>

                <StackPanel x:Name="SourceDescriptionSection" Spacing="8" Visibility="Collapsed">
                    <TextBlock Text="Source description" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <Border
                        Padding="12"
                        CornerRadius="6"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock
                                x:Name="SourceDescriptionText"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                x:Name="SourceDescriptionHintText"
                                Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="SubtasksSection" Spacing="10" Visibility="Collapsed">
                    <TextBlock Text="Subtasks" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <ItemsControl x:Name="SubtasksList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TaskListItemViewModel">
                                <Grid
                                    MinHeight="42"
                                    Padding="0,4"
                                    ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="10">
                                    <CheckBox
                                        Width="24"
                                        Height="24"
                                        Padding="0"
                                        VerticalAlignment="Top"
                                        IsChecked="{Binding Task.IsCompleted, Mode=OneWay}"
                                        Tag="{Binding Id}"
                                        Click="OnSubtaskToggleCompleteClicked"
                                        AutomationProperties.Name="{Binding CompletionAutomationName}" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontWeight="SemiBold"
                                            MaxLines="2"
                                            TextWrapping="WrapWholeWords"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Text="{Binding MetadataText}"
                                            MaxLines="1"
                                            TextTrimming="CharacterEllipsis"
                                            Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock x:Name="OrganizeHeader" Text="Organize" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <ComboBox
                            x:Name="WorkflowEditor"
                            Header="Status"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnWorkflowSelectionChanged">
                            <ComboBoxItem Content="Inbox" Tag="inbox" IsSelected="True" />
                            <ComboBoxItem Content="Next" Tag="next" />
                            <ComboBoxItem Content="Waiting For" Tag="waiting" />
                            <ComboBoxItem Content="Someday" Tag="someday" />
                        </ComboBox>
                        <StackPanel
                            x:Name="ProjectEditor"
                            Grid.Column="1"
                            Spacing="4">
                            <TextBlock Text="Project" />
                            <Button
                                x:Name="ProjectPickerButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                MinHeight="40"
                                Click="OnProjectPickerClicked"
                                AutomationProperties.Name="Choose project">
                                <Button.Flyout>
                                    <Flyout x:Name="ProjectPickerFlyout" Placement="Bottom">
                                        <StackPanel Width="360" Spacing="10">
                                            <AutoSuggestBox
                                                x:Name="ProjectSearchBox"
                                                PlaceholderText="Find or create project"
                                                QueryIcon="Find"
                                                TextChanged="OnProjectSearchTextChanged"
                                                QuerySubmitted="OnProjectSearchSubmitted"
                                                KeyDown="OnProjectSearchKeyDown" />
                                            <ListView
                                                x:Name="ProjectResultsList"
                                                MaxHeight="260"
                                                SelectionMode="None">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ProjectItem">
                                                        <Button
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            Padding="10,8"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Tag="{x:Bind Id}"
                                                            Click="OnProjectResultClicked"
                                                            AutomationProperties.Name="{x:Bind Name}">
                                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                                <FontIcon
                                                                    Glyph="&#xE8B7;"
                                                                    FontSize="13"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Text="{x:Bind Name}"
                                                                    MaxLines="2"
                                                                    TextWrapping="WrapWholeWords"
                                                                    TextTrimming="CharacterEllipsis" />
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <Button
                                                x:Name="CreateProjectButton"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Click="OnCreateProjectClicked" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock
                                        x:Name="ProjectPickerText"
                                        Text="No project"
                                        MaxLines="1"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center" />
                                    <FontIcon
                                        Grid.Column="1"
                                        Glyph="&#xE70D;"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                        <CalendarDatePicker
                            x:Name="DateEditor"
                            Grid.Row="1"
                            Header="Date"
                            PlaceholderText="Add date"
                            HorizontalAlignment="Stretch"
                            DateChanged="OnTaskDateChanged" />
                        <CalendarDatePicker
                            x:Name="DeadlineDateEditor"
                            Grid.Row="1"
                            Grid.Column="1"
                            Header="Deadline"
                            PlaceholderText="Add deadline"
                            HorizontalAlignment="Stretch"
                            DateChanged="OnTaskDateChanged" />
                        <ComboBox
                            x:Name="PriorityEditor"
                            Grid.Row="2"
                            Header="Priority"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="OnSelectionChanged">
                            <ComboBoxItem Content="Urgent" Tag="1" />
                            <ComboBoxItem Content="High" Tag="2" />
                            <ComboBoxItem Content="Normal" Tag="3" />
                            <ComboBoxItem Content="Low" Tag="4" />
                        </ComboBox>
                        <StackPanel
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Spacing="6">
                            <TextBlock Text="Labels" />
                            <Button
                                x:Name="LabelPickerButton"
                                Padding="12,8"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Click="OnLabelPickerClicked"
                                AutomationProperties.Name="Add label">
                                <Button.Flyout>
                                    <Flyout x:Name="LabelPickerFlyout" Placement="BottomEdgeAlignedLeft">
                                        <Grid
                                            Width="380"
                                            MaxHeight="500"
                                            RowDefinitions="Auto,Auto,*"
                                            RowSpacing="12">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Labels" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <TextBlock
                                                    Text="Pick an existing label or type a new one."
                                                    Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                            </StackPanel>
                                            <AutoSuggestBox
                                                x:Name="LabelSearchBox"
                                                Grid.Row="1"
                                                PlaceholderText="Find or create label"
                                                QueryIcon="Find"
                                                TextChanged="OnLabelSearchTextChanged"
                                                QuerySubmitted="OnLabelSearchSubmitted" />
                                            <ListView
                                                x:Name="LabelResultsList"
                                                Grid.Row="2"
                                                MaxHeight="340"
                                                SelectionChanged="OnLabelResultSelectionChanged">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid MinHeight="40" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                            <FontIcon
                                                                Glyph="&#xE8EC;"
                                                                FontSize="14"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                Text="{Binding}"
                                                                TextTrimming="CharacterEllipsis"
                                                                VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <FontIcon
                                        Glyph="&#xE8EC;"
                                        FontSize="14"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="Add label"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <FontIcon
                                        Grid.Column="2"
                                        Glyph="&#xE710;"
                                        FontSize="14"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer
                        MaxHeight="36"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollMode="Disabled">
                        <ItemsControl x:Name="SelectedLabelsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Margin="0,0,6,6"
                                        Padding="10,4"
                                        Click="OnRemoveLabelClicked"
                                        Tag="{Binding Id}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" />
                                            <FontIcon Glyph="&#xE711;" FontSize="10" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <TextBox
                    x:Name="NotesEditor"
                    Header="Notes"
                    PlaceholderText=""
                    AcceptsReturn="True"
                    MinHeight="112"
                    HorizontalAlignment="Stretch"
                    TextChanged="OnEditorChanged" />

                <TextBox
                    x:Name="LabelsEditor"
                    Visibility="Collapsed"
                    Header="Labels"
                    HorizontalAlignment="Stretch"
                    TextChanged="OnEditorChanged" />

                <StackPanel x:Name="ProviderTaskSection" Spacing="10" Visibility="Collapsed">
                    <TextBlock Text="Source task" Style="{StaticResource OpenzaFormSectionHeaderTextBlockStyle}" />
                    <Border
                        Padding="12"
                        CornerRadius="6"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="2">
                                <TextBlock
                                    Text="Title"
                                    Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                <TextBlock
                                    x:Name="ProviderTitleText"
                                    TextWrapping="Wrap"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Project" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderProjectText" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Date" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderDateText" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Spacing="2">
                                    <TextBlock Text="Deadline" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderDeadlineText" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Priority" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderPriorityText" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Spacing="2">
                                    <TextBlock Text="Source" Style="{StaticResource OpenzaMetadataTextBlockStyle}" />
                                    <TextBlock x:Name="ProviderSourceText" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid
            Grid.Row="2"
            Padding="20,14"
            ColumnDefinitions="Auto,Auto,*,Auto,Auto"
            ColumnSpacing="8"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Button
                x:Name="SaveButton"
                Content="Save"
                Style="{StaticResource AccentButtonStyle}"
                Click="OnSaveTaskClicked" />
            <Button
                Grid.Column="1"
                Content="Cancel"
                Click="OnCancelEditClicked" />
            <Button
                x:Name="DeleteButton"
                Grid.Column="3"
                Content="Delete"
                IsEnabled="False"
                Click="OnDeleteTaskClicked" />
            <Button
                x:Name="CompleteButton"
                Grid.Column="4"
                Content="Complete"
                IsEnabled="False"
                Click="OnToggleCompleteClicked" />
        </Grid>
    </Grid>
</UserControl>
