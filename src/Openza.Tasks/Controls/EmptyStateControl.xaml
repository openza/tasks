<UserControl
    x:Class="Openza.Tasks.Controls.EmptyStateControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        MaxWidth="360"
        Spacing="8">
        <FontIcon
            Glyph="&#xE73E;"
            FontSize="36"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        <TextBlock
            Text="{x:Bind Title, Mode=OneWay}"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            TextAlignment="Center" />
        <TextBlock
            Text="{x:Bind Message, Mode=OneWay}"
            Style="{StaticResource OpenzaMetadataTextBlockStyle}"
            TextAlignment="Center"
            TextWrapping="Wrap" />
        <Button
            Margin="0,8,0,0"
            HorizontalAlignment="Center"
            Content="{x:Bind ActionText, Mode=OneWay}"
            Visibility="{x:Bind ActionVisibility, Mode=OneWay}"
            Click="OnActionClicked" />
    </StackPanel>
</UserControl>
