<UserControl
    x:Class="Openza.Tasks.Shell.AppShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Openza.Tasks.Pages">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <NavigationView
            x:Name="ShellNav"
            PaneDisplayMode="Left"
            IsPaneOpen="True"
            OpenPaneLength="220"
            CompactPaneLength="56"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#1A2563EB" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#242563EB" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="#2E2563EB" />
            </NavigationView.Resources>
            <NavigationView.PaneHeader>
                <ComboBox
                    x:Name="SpaceSelector"
                    Margin="12,8,12,8"
                    HorizontalAlignment="Stretch"
                    DisplayMemberPath="Name"
                    SelectedValuePath="Id"
                    SelectionChanged="OnSpaceSelectionChanged"
                    AutomationProperties.Name="Current space" />
            </NavigationView.PaneHeader>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="AddTaskNavItem"
                    Margin="6,4,6,6"
                    Background="{StaticResource OpenzaAccentBrush}"
                    Foreground="{StaticResource OpenzaOnAccentBrush}"
                    SelectsOnInvoked="False"
                    Tag="add-task"
                    PointerEntered="OnAddTaskPointerEntered"
                    PointerExited="OnAddTaskPointerExited"
                    PointerPressed="OnAddTaskPointerPressed"
                    PointerReleased="OnAddTaskPointerEntered"
                    ToolTipService.ToolTip="Add task">
                    <NavigationViewItem.Resources>
                        <SolidColorBrush x:Key="NavigationViewItemBackground" Color="#2563EB" />
                        <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#1D4ED8" />
                        <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="#1E40AF" />
                        <SolidColorBrush x:Key="NavigationViewItemForeground" Color="#FFFFFFFF" />
                        <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="#FFFFFFFF" />
                        <SolidColorBrush x:Key="NavigationViewItemForegroundPressed" Color="#FFFFFFFF" />
                        <SolidColorBrush x:Key="NavigationViewItemIconForeground" Color="#FFFFFFFF" />
                        <SolidColorBrush x:Key="NavigationViewItemIconForegroundPointerOver" Color="#FFFFFFFF" />
                        <SolidColorBrush x:Key="NavigationViewItemIconForegroundPressed" Color="#FFFFFFFF" />
                    </NavigationViewItem.Resources>
                    <NavigationViewItem.Content>
                        <TextBlock
                            Text="Add task"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource OpenzaOnAccentBrush}" />
                    </NavigationViewItem.Content>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE710;" Foreground="{StaticResource OpenzaOnAccentBrush}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem x:Name="InboxNavItem" Content="Inbox" Tag="inbox">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="InboxBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE715;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NextNavItem" Content="Next Actions" Tag="next">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="NextBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="TodayNavItem" Content="Today" Tag="today">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="TodayBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="CalendarNavItem" Content="Calendar" Tag="calendar">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="CalendarBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE163;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="OverdueNavItem" Content="Overdue" Tag="overdue">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="OverdueBadge" Style="{StaticResource OpenzaNavDangerInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="WaitingNavItem" Content="Waiting For" Tag="waiting">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="WaitingBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SomedayNavItem" Content="Someday" Tag="someday">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="SomedayBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="TasksNavItem" Content="Tasks" Tag="tasks">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="TasksBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="CompletedNavItem" Content="Completed" Tag="completed">
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="CompletedBadge" Style="{StaticResource OpenzaNavInfoBadgeStyle}" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sync" Tag="sync">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE895;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid RowDefinitions="Auto,*">
                <InfoBar
                    x:Name="StatusInfo"
                    IsOpen="False"
                    IsClosable="True"
                    Margin="20,12,20,0" />

                <Grid Grid.Row="1">
                    <pages:TasksPage
                        x:Name="TasksPage"
                        SearchTextChanged="OnSearchTextChanged"
                        SortChanged="OnSortChanged"
                        GroupChanged="OnGroupChanged"
                        PriorityChanged="OnPriorityChanged"
                        RepeatScopeChanged="OnRepeatScopeChanged"
                        LabelChanged="OnLabelChanged"
                        ProjectSearchTextChanged="OnProjectSearchTextChanged"
                        ProjectFilterChanged="OnProjectFilterChanged"
                        ProjectSelected="OnProjectSelected"
                        ClearProjectClicked="OnClearProjectClicked"
                        AddProjectClicked="OnAddProjectClicked"
                        EditProjectClicked="OnEditProjectClicked"
                        DeleteProjectClicked="OnDeleteProjectClicked"
                        TaskSelected="OnTaskSelected"
                        ToggleCompleteClicked="OnToggleCompleteClicked"
                        CopyTaskIdClicked="OnCopyTaskIdClicked"
                        DeleteTaskClicked="OnDeleteTaskClicked"
                        SaveTaskClicked="OnSaveTaskClicked"
                        DetailsToggleCompleteClicked="OnDetailsToggleCompleteClicked"
                        DetailsDeleteTaskClicked="OnDetailsDeleteTaskClicked"
                        DetailsCancelEditClicked="OnDetailsCancelEditClicked"
                        QuickAddClicked="OnQuickAddClicked"
                        ImportClicked="OnImportClicked"
                        ExportClicked="OnExportClicked"
                        ConnectProvidersClicked="OnConnectProvidersClicked"
                        ExploreSyncClicked="OnExploreSyncClicked"
                        DismissGetStartedClicked="OnDismissGetStartedClicked"
                        AddConnectedTaskClicked="OnAddSourceClicked"
                        SkipConnectedTaskClicked="OnSkipSourceClicked"
                        UnskipConnectedTaskClicked="OnUnskipSourceClicked"
                        ReviewConnectedTasksClicked="OnReviewConnectedTasksClicked"
                        ShowSkippedConnectedTasksChanged="OnShowSkippedConnectedTasksChanged"
                        AddAllConnectedTasksClicked="OnAddAllConnectedTasksClicked" />

                    <Grid
                        x:Name="SettingsWorkspace"
                        Visibility="Collapsed"
                        Padding="40,32"
                        SizeChanged="OnPageWorkspaceSizeChanged">
                        <pages:SettingsPage
                            x:Name="SettingsPage"
                            HorizontalAlignment="Left"
                            ThemeChanged="OnThemeChanged"
                            ConnectTodoistClicked="OnConnectTodoistClicked"
                            ConnectMicrosoftClicked="OnConnectMicrosoftClicked"
                            DisconnectTodoistClicked="OnDisconnectTodoistClicked"
                            DisconnectMicrosoftClicked="OnDisconnectMicrosoftClicked"
                            CreateBackupClicked="OnCreateBackupClicked"
                            RestoreBackupClicked="OnRestoreBackupClicked"
                            RefreshBackupsClicked="OnRefreshBackupsClicked"
                            ExportBackupClicked="OnExportBackupClicked"
                            RestoreSelectedBackupClicked="OnRestoreSelectedBackupClicked"
                            DeleteBackupClicked="OnDeleteBackupClicked"
                            AutoBackupToggled="OnAutoBackupToggled"
                            AutoSyncToggled="OnAutoSyncToggled"
                            AddSpaceClicked="OnAddSpaceClicked"
                            RenameSpaceClicked="OnRenameSpaceClicked"
                            ArchiveSpaceClicked="OnArchiveSpaceClicked" />
                    </Grid>

                    <ScrollViewer
                        x:Name="SyncWorkspace"
                        Visibility="Collapsed"
                        Padding="40,32"
                        HorizontalScrollBarVisibility="Disabled"
                        SizeChanged="OnPageWorkspaceSizeChanged">
                        <pages:SyncPage
                            x:Name="SyncPage"
                            HorizontalAlignment="Left"
                            RunSyncClicked="OnSyncClicked"
                            OpenSettingsClicked="OnOpenSettingsFromSyncClicked"
                            OpenInboxClicked="OnOpenInboxFromSyncClicked" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</UserControl>
