# Openza Tasks local environment template
#
# The WinUI app stores provider tokens in Windows Credential Locker.
# Do not put real tokens or Store-private data in this file.

# Reserved for future Openza Sync service/CLI experiments.
OPENZA_TASKS_ENV=development

# Optional for source builds. Public Azure app registration values only; never put secrets here.
# Register ms-appx-web://microsoft.aad.brokerplugin/{client_id} as the WAM redirect URI.
OPENZA_TASKS_MSTODO_CLIENT_ID=
OPENZA_TASKS_MSTODO_TENANT_ID=common
